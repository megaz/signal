ENV=development
SECRET_KEY=changeme

# Local DB
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse
# Managed/public Postgres (Neon/Supabase/Railway):
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<db>?ssl=require
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000

# Docker Compose overrides DATABASE_URL/REDIS_URL for the api service.
# The web service uses API_INTERNAL_URL=http://api:8000 for server-side API proxying.

META_ACCESS_TOKEN=
META_API_VERSION=v19.0

TIKTOK_APP_ID=
TIKTOK_SECRET=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

LUMA_API_KEY=

SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Apify (scripts/run_tiktok_apify_ingestion.sh + ingestion/tiktok_apify.py)
APIFY_TOKEN=
